{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "api/generate.py", "use": "@vercel/python", "config": { "maxDuration": 60 } },
    { "src": "api/freebies.py", "use": "@vercel/python" }
  ],
  "routes": [
    { "src": "/api/generate", "dest": "/api/generate.py" },
    { "src": "/api/freebies", "dest": "/api/freebies.py" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
